<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_dialog"
    android:paddingBottom="24dp"
    android:focusable="true"
    android:focusableInTouchMode="true">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_word_detail"
            android:textColor="@color/gray_900"
            android:textSize="20sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            
            <ImageButton
                android:id="@+id/btnDelete"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@android:drawable/ic_menu_delete"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/gray_500" />
                
            <Space android:layout_width="8dp" android:layout_height="wrap_content" />
            
            <ImageButton
                android:id="@+id/btnClose"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_close"
                android:background="?attr/selectableItemBackgroundBorderless"
                app:tint="@color/gray_500" />
        </LinearLayout>
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_200" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp">

        <!-- 원어 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/header_original_word"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etOriginalWord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:text="-"
                android:textColor="@color/gray_900"
                android:textSize="16sp"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false" />
            <ImageButton
                android:id="@+id/btnEditOriginalWord"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_carrot_edit"
                android:scaleX="1.6"
                android:scaleY="1.6"
                android:scaleType="fitCenter"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_100" />

        <!-- 발음 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/header_reading"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etReading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:text="-"
                android:textColor="@color/gray_900"
                android:textSize="16sp"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false" />
            <ImageButton
                android:id="@+id/btnEditReading"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_carrot_edit"
                android:scaleX="1.6"
                android:scaleY="1.6"
                android:scaleType="fitCenter"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_100" />

        <!-- 한국어 뜻 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/header_meaning"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                android:textStyle="bold" />
            <EditText
                android:id="@+id/etMeaning"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@null"
                android:text="-"
                android:textColor="@color/gray_900"
                android:textSize="16sp"
                android:singleLine="true"
                android:imeOptions="actionDone"
                android:focusable="false"
                android:focusableInTouchMode="false"
                android:cursorVisible="false" />
            <ImageButton
                android:id="@+id/btnEditMeaning"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_carrot_edit"
                android:scaleX="1.6"
                android:scaleY="1.6"
                android:scaleType="fitCenter"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_100" />

        <!-- 등록 날짜 -->
        <LinearLayout
            android:id="@+id/layoutCreatedAt"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_created_at"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvCreatedAt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="@color/gray_900"
                android:textSize="16sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/gray_100" />

        <!-- 기억 여부 -->
        <LinearLayout
            android:id="@+id/layoutMemorizedStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_memorized_status"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvMemorizedStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_primary"
                android:text="@string/status_not_memorized"
                android:textColor="@color/brand_pink"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 언어 선택 -->
        <LinearLayout
            android:id="@+id/layoutLanguage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/label_language_select"
                android:textColor="@color/gray_500"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvLanguageSelect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_primary"
                android:text="@string/lang_en_short"
                android:textColor="@color/brand_pink"
                android:textSize="12sp"
                android:textStyle="bold"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:gravity="center_vertical">
        
        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/action_confirm"
            android:textColor="@color/white"
            android:backgroundTint="@color/brand_pink_light" />
    </LinearLayout>

</LinearLayout>
