<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="24dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="단어 상세 정보"
            android:textColor="@color/color_111827"
            android:textSize="20sp"
            android:textStyle="bold" />

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_close"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/color_6b7280" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_e5e7eb" />

    <!-- Content -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp">

        <!-- 원어 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="원어"
                android:textColor="@color/color_6b7280"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvOriginalWord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="@color/color_111827"
                android:textSize="16sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_f3f4f6" />

        <!-- 발음 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="발음"
                android:textColor="@color/color_6b7280"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvReading"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="@color/color_111827"
                android:textSize="16sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_f3f4f6" />

        <!-- 한국어 뜻 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="한국어 뜻"
                android:textColor="@color/color_6b7280"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvTranslatedWord"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="@color/color_111827"
                android:textSize="16sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_f3f4f6" />

        <!-- 등록 날짜 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="등록 날짜"
                android:textColor="@color/color_6b7280"
                android:textSize="14sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tvCreatedAt"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="-"
                android:textColor="@color/color_111827"
                android:textSize="16sp" />
        </LinearLayout>
        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/color_f3f4f6" />

        <!-- 기억 여부 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingVertical="16dp"
            android:gravity="center_vertical">
            <TextView
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="기억 여부"
                android:textColor="@color/color_6b7280"
                android:textSize="14sp"
                android:textStyle="bold" />
            
            <TextView
                android:id="@+id/tvMemorizedStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:background="@drawable/bg_badge_primary"
                android:text="미완료"
                android:textColor="@color/color_ff85b2"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

    </LinearLayout>

    <!-- Actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:gravity="center_vertical">
        
        <Button
            android:id="@+id/btnDelete"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="삭제"
            android:textColor="@color/color_ff85b2"
            android:backgroundTint="@color/color_ffffff"
            style="?attr/materialButtonOutlinedStyle"
            app:strokeColor="@color/color_ff85b2" />
            
        <Space android:layout_width="16dp" android:layout_height="wrap_content" />
        
        <Button
            android:id="@+id/btnConfirm"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="확인"
            android:textColor="@color/color_ffffff"
            android:backgroundTint="@color/color_0058be" />
    </LinearLayout>

</LinearLayout>
