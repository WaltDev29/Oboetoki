<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/white">

    <include layout="@layout/layout_header" />

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/white"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="45dp"
            android:layout_height="45dp"
            android:src="@drawable/ic_filter"
            android:background="@color/white"
            android:scaleType="center"
            app:tint="@color/brand_pink_dark"
            android:contentDescription="필터" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@drawable/bg_search_bar"
            android:hint="@string/hint_search_word"
            android:paddingHorizontal="16dp"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:drawableTint="@color/brand_pink_circle"
            android:textSize="14sp"
            android:inputType="text" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tableHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp">

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp">
            <TextView
                android:id="@+id/tvHeaderOriginal"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:paddingVertical="6dp"
                android:text="@string/header_original_word"
                android:textStyle="bold"
                android:textColor="@color/color_header_btn_text"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_header_btn" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp">
            <TextView
                android:id="@+id/tvHeaderReading"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:paddingVertical="6dp"
                android:text="@string/header_reading"
                android:textStyle="bold"
                android:textColor="@color/color_header_btn_text"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_header_btn" />
        </FrameLayout>

        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginHorizontal="2dp">
            <TextView
                android:id="@+id/tvHeaderTranslated"
                android:layout_width="64dp"
                android:layout_height="wrap_content"
                android:layout_gravity="start|center_vertical"
                android:paddingVertical="6dp"
                android:text="@string/header_meaning"
                android:textStyle="bold"
                android:textColor="@color/color_header_btn_text"
                android:textSize="13sp"
                android:gravity="center"
                android:clickable="true"
                android:focusable="true"
                android:background="@drawable/bg_header_btn" />
        </FrameLayout>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:paddingBottom="80dp"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_vocabulary" />

        <com.google.android.material.floatingactionbutton.FloatingActionButton
            android:id="@+id/fabAddWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="20dp"
            app:backgroundTint="@color/brand_pink_dark"
            app:tint="@color/white"
            app:borderWidth="0dp"
            app:elevation="4dp"
            app:fabSize="normal"
            android:src="@android:drawable/ic_input_add"
            android:contentDescription="단어 추가" />
    </FrameLayout>

    <include
        android:id="@+id/includedBottomNav"
        layout="@layout/layout_bottom_navigation" />

    <!-- Bottom Actions for OCR Saving -->
    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/white"
        android:visibility="gone">

        <Button
            android:id="@+id/btnSaveBatch"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/action_add_all"
            android:backgroundTint="@color/blue_700"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/action_cancel"
            android:backgroundTint="@color/white"
            android:textColor="@color/brand_pink"
            android:textStyle="bold"
            style="?attr/materialButtonOutlinedStyle"
            app:strokeColor="@color/brand_pink" />
    </LinearLayout>

</LinearLayout>
