<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/color_f9fafb">

    <include layout="@layout/layout_header" />

    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/color_ffffff"
        android:gravity="center_vertical">

        <ImageButton
            android:id="@+id/btnFilter"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_book"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="필터" />

        <EditText
            android:id="@+id/etSearch"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_marginStart="12dp"
            android:background="@color/color_f3f4f6"
            android:hint="@string/str_38"
            android:paddingHorizontal="16dp"
            android:textSize="14sp"
            android:inputType="text" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/tableHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingVertical="12dp"
        android:background="#FCE7F3">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/str_36"
            android:textStyle="bold"
            android:textColor="@color/color_374151"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/str_reading"
            android:textStyle="bold"
            android:textColor="@color/color_374151"
            android:textSize="14sp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/str_37"
            android:textStyle="bold"
            android:textColor="@color/color_374151"
            android:textSize="14sp" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        tools:listitem="@layout/item_vocabulary" />

    <include
        android:id="@+id/includedBottomNav"
        layout="@layout/layout_bottom_navigation" />

    <!-- Bottom Actions for OCR Saving -->
    <LinearLayout
        android:id="@+id/bottomLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:background="@color/color_ffffff"
        android:visibility="gone">

        <Button
            android:id="@+id/btnSaveBatch"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="@string/str_4"
            android:backgroundTint="@color/color_0058be"
            android:textColor="@color/color_ffffff"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnCancel"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            android:text="@string/str_5"
            android:backgroundTint="@color/color_ffffff"
            android:textColor="@color/color_ff85b2"
            android:textStyle="bold"
            style="?attr/materialButtonOutlinedStyle"
            app:strokeColor="@color/color_ff85b2" />
    </LinearLayout>

</LinearLayout>
